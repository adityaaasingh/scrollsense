{
  "manifest_version": 3,
  "name": "ScrollSense",
  "version": "0.1.0",
  "description": "Classifies content from the current tab using AI.",

  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Open ScrollSense"
  }
}
